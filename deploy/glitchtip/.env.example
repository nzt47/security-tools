# ============================================================================
# GlitchTip 生产环境变量配置模板
# ============================================================================
# 用途：deploy/glitchtip/docker-compose.yml 的环境变量来源
# 使用方式：
#   cd deploy/glitchtip
#   cp .env.example .env
#   # 按下方注释逐项修改，标记 [生产必改] 的项目必须修改默认值
# ============================================================================
# 注意：本文件为生产环境模板，与 docker/glitchtip/.env.example（开发环境）隔离。
#       两者端口/密码/密钥互不干扰，可并行运行。
# ============================================================================


# ─── 数据库配置 ──────────────────────────────────────────
# [生产必改] 数据库名称（建议使用非默认名称增加安全性）
POSTGRES_DB=glitchtip

# [生产必改] 数据库用户名
POSTGRES_USER=glitchtip

# [生产必改] 数据库密码，必须修改为强密码（至少 16 位，含大小写字母+数字+特殊字符）
# 生成建议：python -c "import secrets; print(secrets.token_urlsafe(24))"
POSTGRES_PASSWORD=glitchtip_prod_pass_change_me

# PostgreSQL 最大连接数（根据并发量调整，默认 100）
# 注意：每个 GlitchTip web/worker 进程都会占用连接，生产建议 100-200
POSTGRES_MAX_CONNECTIONS=100


# ─── GlitchTip 核心配置 ──────────────────────────────────
# [生产必改] Django SECRET_KEY，用于会话签名、CSRF 保护等
# 生成命令（任选其一）：
#   python -c "import secrets; print(secrets.token_urlsafe(50))"
#   openssl rand -base64 50
# 要求：至少 50 字符的随机字符串，禁止使用默认值
SECRET_KEY=prod-secret-key-must-change

# GlitchTip 运行环境标识（用于事件分类）
# 可选值：production / staging / development
SENTRY_ENVIRONMENT=production

# Sentry SDK 采样率（0.0~1.0）
# 生产建议 1.0（全量采样），高流量场景可降至 0.5
SENTRY_SAMPLE_RATE=1.0

# 性能追踪采样率（0.0~1.0）
# 生产建议 0.1~0.3，过高会影响性能
SENTRY_TRACES_SAMPLE_RATE=0.1


# ─── 域名配置 ──────────────────────────────────────────
# GlitchTip 访问地址（用于生成 DSN 和邮件链接中的域名）
# 生产环境务必改为实际域名，例如：https://glitchtip.your-domain.com
# 若使用反向代理，需与代理对外暴露的协议+域名一致
GLITCHTIP_DOMAIN=http://localhost:8001


# ─── 社交登录（可选） ────────────────────────────────────
# 是否启用社交登录（True/False）
ENABLE_SOCIAL_AUTH=False

# GitHub OAuth（启用时取消注释并填写）
# SOCIAL_AUTH_GITHUB_CLIENT_ID=
# SOCIAL_AUTH_GITHUB_SECRET=

# GitLab OAuth（启用时取消注释并填写）
# SOCIAL_AUTH_GITLAB_CLIENT_ID=
# SOCIAL_AUTH_GITLAB_SECRET=
# SOCIAL_AUTH_GITLAB_API_URL=https://gitlab.com


# ─── 邮件通知（可选） ────────────────────────────────────
# 邮件服务 URL，格式：smtp://user:pass@smtp.example.com:587
# 留空则不发送邮件通知；开发调试可用 console://（仅打印到日志）
# EMAIL_URL=smtp://user:pass@smtp.example.com:587
EMAIL_URL=

# 发件人地址（邮件通知使用）
DEFAULT_FROM_EMAIL=noreply@localhost


# ─── 资源限制配置 ──────────────────────────────────────
# Celery Worker 自动伸缩策略（最小,最大 进程数）
# 生产建议根据 CPU 核数调整：1,3（单核）或 2,8（多核）
CELERY_WORKER_AUTOSCALE=1,3

# Celery Worker 单进程最大处理任务数（防内存泄漏）
# 达到阈值后 worker 进程会重启释放内存，生产建议 100-500
CELERY_WORKER_MAX_TASKS_PER_CHILD=100


# ─── 日志级别 ──────────────────────────────────────────
# Django 日志级别（DEBUG/INFO/WARNING/ERROR/CRITICAL）
# 生产环境禁止使用 DEBUG（会暴露敏感信息）
# INFO：记录常规请求；WARNING：仅记录警告以上；ERROR：仅记录错误
DJANGO_LOG_LEVEL=INFO


# ─── 时区配置 ──────────────────────────────────────────
# 容器时区（影响日志时间戳和 Celery 定时任务）
TZ=Asia/Shanghai


# ─── 健康检查 ──────────────────────────────────────────
# GlitchTip 心跳端点（供外部监控/负载均衡探测）
# 与 docker-compose.yml 中 web 服务 healthcheck 一致
HEALTHCHECK_URL=http://localhost:8001/api/0/heartbeat/
