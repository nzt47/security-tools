# Sentry DSN（从 GlitchTip 项目设置获取，留空则不启用错误上报）
VITE_SENTRY_DSN=

# Sentry 环境（development/staging/production）
VITE_SENTRY_ENVIRONMENT=development

# 性能追踪采样率（0-1，生产建议 0.01）
VITE_SENTRY_TRACES_SAMPLE_RATE=0.01

# 行为回放采样率（0-1，生产建议 0.01 = 1%）
VITE_SENTRY_REPLAYS_SAMPLE_RATE=0.01

# rrweb 录制采样率（0-1，覆盖 Sentry replay，独立控制；默认 0.01 = 1%）
VITE_REPLAY_SAMPLE_RATE=0.01

# 应用版本号（用于 Sentry release 字段）
VITE_APP_VERSION=0.0.0

# 后端回放上传端点（默认同源 /api/replay/upload）
VITE_REPLAY_UPLOAD_URL=/api/replay/upload
