# 开发环境：开启可观测性
VITE_OBSERVABILITY_ENABLED=true
VITE_OBS_MAX_RECORDS=200
VITE_OBS_SAMPLING_RATE=1

# 开发环境：启用 mock trace_id 注入（无需后端即可验证 DevConsole trace_id 解析）
# 设为 false 则关闭 mock，请求会走真实后端或代理
VITE_MOCK_TRACE=true

# Sentry 错误上报（自建 GlitchTip 后端，留空则禁用）
# 本地开发可不配置；如需联调，使用本地 GlitchTip 实例的 DSN
VITE_SENTRY_DSN=
VITE_SENTRY_SAMPLE_RATE=1
VITE_SENTRY_TRACES_SAMPLE_RATE=0

# 用户行为回放（rrweb）采样率
# 默认 1%：仅采样 1% 的会话录制；发生错误时自动 100% 上传最近 30 秒
VITE_REPLAY_SAMPLE_RATE=0.01
