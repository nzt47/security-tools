      "description": "正常对话请求 - 返回响应文本与模式信息",
      "request": {
        "method": "POST",
        "path": "/api/chat",
        "headers": {},
        "query": {},
        "body_fields": [
          {
            "name": "message",
            "type": "string",
            "required": true,
            "description": "用户输入消息",
            "min_length": 1,
            "max_length": 10000
