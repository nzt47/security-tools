              "required": true,
              "description": "日志条目"
            }
          },
          {
            "name": "timing",
            "type": "object",
            "required": true,
            "description": "耗时统计",
            "properties": [
              {
                "name": "total",
                "type": "number",
                "required": true,
                "description": "总耗时(ms)"
              },
              {
                "name": "safety_check",
                "type": "number",
                "required": true,
                "description": "安全检查耗时(ms)"
              },
              {
                "name": "chat_processing",
                "type": "number",
                "required": true,
                "description": "对话处理耗时(ms)"
              }
            ]
          },
          {
            "name": "health",
            "type": "array",
            "required": false,
            "description": "身体状态读数",
            "items": {
              "name": "reading",
              "type": "object",
              "required": true,
              "description": "身体状态读数",
              "properties": [
                {
                  "name": "sensor_name",
                  "type": "string",
                  "required": true,
                  "description": ""
                },
                {
                  "name": "severity",
                  "type": "string",
                  "required": true,
                  "description": "",
                  "enum": [
                    "normal",
                    "warning",
                    "critical"
                  ]
                }
              ]
            }
          },
          {
            "name": "llm_state",
            "type": "object",
            "required": false,
            "description": "LLM 配置状态",
            "properties": [
              {
                "name": "configured",
                "type": "boolean",
                "required": true,
                "description": ""
              },
              {
                "name": "provider",
                "type": "string",
                "required": true,
                "description": ""
              },
              {
                "name": "api_key_set",
                "type": "boolean",
                "required": true,
                "description": ""
              }
            ]
          }
        ],
        "example": {
          "response": "您好，我是云枢。",
          "mode": "normal",
          "mode_label": "正常模式",
