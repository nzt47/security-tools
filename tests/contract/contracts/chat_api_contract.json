        "status": 200,
        "headers": {
          "Content-Type": "application/json"
        },
        "body_fields": [
          {
            "name": "response",
            "type": "string",
            "required": true,
            "description": "对话响应文本"
          },
          {
            "name": "mode",
            "type": "string",
            "required": true,
            "description": "行为模式",
