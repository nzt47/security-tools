# GlitchTip 环境变量配置
# 复制此文件为 .env 并修改相应值

# ─── 数据库配置 ──────────────────────────────────────────
POSTGRES_DB=glitchtip
POSTGRES_USER=glitchtip
POSTGRES_PASSWORD=glitchtip_dev_pass

# ─── GlitchTip 核心配置 ──────────────────────────────────
# 生产环境务必修改为随机字符串（至少 50 字符）
SECRET_KEY=dev-secret-key-change-in-production

# GlitchTip 访问地址（用于生成 DSN 和邮件链接）
GLITCHTIP_DOMAIN=http://localhost:8000

# ─── 社交登录（可选） ────────────────────────────────────
ENABLE_SOCIAL_AUTH=False
# SOCIAL_AUTH_GITHUB_CLIENT_ID=
# SOCIAL_AUTH_GITHUB_SECRET=

# ─── 邮件通知（可选） ────────────────────────────────────
# 格式：smtp://user:pass@smtp.gmail.com:587 或 console://
# EMAIL_URL=smtp://user:pass@smtp.example.com:587
# DEFAULT_FROM_EMAIL=noreply@example.com
