<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>云枢 (Yunshu) — 数字生命体系统架构 Architecture Diagram</title>
  <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;600;700&display=swap" rel="stylesheet">
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: 'JetBrains Mono', monospace;
      background: #020617;
      min-height: 100vh;
      padding: 2rem;
      color: white;
    }

    .container {
      max-width: 1200px;
      margin: 0 auto;
    }

    .header {
      margin-bottom: 2rem;
    }

    .header-row {
      display: flex;
      align-items: center;
      gap: 1rem;
      margin-bottom: 0.5rem;
    }

    .pulse-dot {
      width: 12px;
      height: 12px;
      background: #22d3ee;
      border-radius: 50%;
      animation: pulse 2s infinite;
    }

    @keyframes pulse {
      0%, 100% { opacity: 1; }
      50% { opacity: 0.5; }
    }

    h1 {
      font-size: 1.5rem;
      font-weight: 700;
      letter-spacing: -0.025em;
    }

    .subtitle {
      color: #94a3b8;
      font-size: 0.875rem;
      margin-left: 1.75rem;
    }

    .diagram-container {
      background: rgba(15, 23, 42, 0.5);
      border-radius: 1rem;
      border: 1px solid #1e293b;
      padding: 1.5rem;
      overflow-x: auto;
    }

    svg {
      width: 100%;
      min-width: 900px;
      display: block;
    }

    .cards {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 1rem;
      margin-top: 2rem;
    }

    .card {
      background: rgba(15, 23, 42, 0.5);
      border-radius: 0.75rem;
      border: 1px solid #1e293b;
      padding: 1.25rem;
    }

    .card-header {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      margin-bottom: 0.75rem;
    }

    .card-dot {
      width: 8px;
      height: 8px;
      border-radius: 50%;
    }

    .card-dot.cyan { background: #22d3ee; }
    .card-dot.emerald { background: #34d399; }
    .card-dot.violet { background: #a78bfa; }
    .card-dot.amber { background: #fbbf24; }
    .card-dot.rose { background: #fb7185; }

    .card h3 {
      font-size: 0.875rem;
      font-weight: 600;
    }

    .card ul {
      list-style: none;
      color: #94a3b8;
      font-size: 0.75rem;
    }

    .card li {
      margin-bottom: 0.375rem;
    }

    .footer {
      text-align: center;
      margin-top: 1.5rem;
      color: #475569;
      font-size: 0.75rem;
    }
  </style>
</head>
<body>
  <div class="container">
    <!-- Header -->
    <div class="header">
      <div class="header-row">
        <div class="pulse-dot"></div>
        <h1>云枢 (Yunshu) — 数字生命体系统架构 Architecture</h1>
      </div>
      <p class="subtitle">云枢 (Yunshu) — 数字生命体系统架构 - 15 components</p>
    </div>

    <!-- Main Diagram -->
    <div class="diagram-container">
      <svg viewBox="0 0 1000 680">
        <!-- Definitions -->
        <defs>
          <marker id="arrowhead" markerWidth="10" markerHeight="7" refX="9" refY="3.5" orient="auto">
            <polygon points="0 0, 10 3.5, 0 7" fill="#64748b" />
          </marker>
          <pattern id="grid" width="40" height="40" patternUnits="userSpaceOnUse">
            <path d="M 40 0 L 0 0 0 40" fill="none" stroke="#1e293b" stroke-width="0.5"/>
          </pattern>
        </defs>

        <!-- Background Grid -->
        <rect width="100%" height="100%" fill="url(#grid)" />

        <!-- Components -->
        <rect x="40" y="80" width="180" height="56" rx="6" fill="rgba(6, 78, 59, 0.4)" stroke="#34d399" stroke-width="1.5"/>
        <text x="130" y="102" fill="white" font-size="12" font-weight="600" text-anchor="middle" font-family="JetBrains Mono, monospace">LLM 大模型大脑</text>
        <text x="130" y="120" fill="#94a3b8" font-size="8" text-anchor="middle" font-family="JetBrains Mono, monospace">OpenAI / Claude / 本地模型 — 核心认知引擎</text>
        <rect x="250" y="80" width="180" height="56" rx="6" fill="rgba(6, 78, 59, 0.4)" stroke="#34d399" stroke-width="1.5"/>
        <text x="340" y="102" fill="white" font-size="12" font-weight="600" text-anchor="middle" font-family="JetBrains Mono, monospace">行为控制器</text>
        <text x="340" y="120" fill="#94a3b8" font-size="8" text-anchor="middle" font-family="JetBrains Mono, monospace">正常/安全/省电/内存整理/离线/警告 六种行为模式</text>
        <rect x="460" y="80" width="180" height="56" rx="6" fill="rgba(6, 78, 59, 0.4)" stroke="#34d399" stroke-width="1.5"/>
        <text x="550" y="102" fill="white" font-size="10" font-weight="600" text-anchor="middle" font-family="JetBrains Mono, monospace">感知系统 (Sensors)</text>
        <text x="550" y="120" fill="#94a3b8" font-size="8" text-anchor="middle" font-family="JetBrains Mono, monospace">CPU/内存/磁盘/电池/网络/温度/GPU/进程/端口 传感器</text>
        <rect x="670" y="80" width="180" height="56" rx="6" fill="rgba(6, 78, 59, 0.4)" stroke="#34d399" stroke-width="1.5"/>
        <text x="760" y="102" fill="white" font-size="10" font-weight="600" text-anchor="middle" font-family="JetBrains Mono, monospace">记忆系统 (Memory)</text>
        <text x="760" y="120" fill="#94a3b8" font-size="8" text-anchor="middle" font-family="JetBrains Mono, monospace">短期记忆(RAM) → 中期记忆(Summary) → 长期记忆(BlackBox+向量DB)</text>
        <rect x="40" y="166" width="180" height="56" rx="6" fill="rgba(6, 78, 59, 0.4)" stroke="#34d399" stroke-width="1.5"/>
        <text x="130" y="188" fill="white" font-size="10" font-weight="600" text-anchor="middle" font-family="JetBrains Mono, monospace">认知系统 (Cognitive)</text>
        <text x="130" y="206" fill="#94a3b8" font-size="8" text-anchor="middle" font-family="JetBrains Mono, monospace">提示词注入 / 思维模板 / 翻译器 / Flask适配器</text>
        <rect x="250" y="166" width="180" height="56" rx="6" fill="rgba(6, 78, 59, 0.4)" stroke="#34d399" stroke-width="1.5"/>
        <text x="340" y="188" fill="white" font-size="10" font-weight="600" text-anchor="middle" font-family="JetBrains Mono, monospace">人格系统 (Persona)</text>
        <text x="340" y="206" fill="#94a3b8" font-size="9" text-anchor="middle" font-family="JetBrains Mono, monospace">个性风格 / 情感表达 / 语气语调管理</text>
        <rect x="460" y="166" width="180" height="56" rx="6" fill="rgba(6, 78, 59, 0.4)" stroke="#34d399" stroke-width="1.5"/>
        <text x="550" y="188" fill="white" font-size="10" font-weight="600" text-anchor="middle" font-family="JetBrains Mono, monospace">生命周期追踪 (LifeTrace)</text>
        <text x="550" y="206" fill="#94a3b8" font-size="9" text-anchor="middle" font-family="JetBrains Mono, monospace">交互轨迹记录 / 状态快照 / 成长历程</text>
        <rect x="670" y="166" width="180" height="56" rx="6" fill="rgba(6, 78, 59, 0.4)" stroke="#34d399" stroke-width="1.5"/>
        <text x="760" y="188" fill="white" font-size="10" font-weight="600" text-anchor="middle" font-family="JetBrains Mono, monospace">监控系统 (Monitoring)</text>
        <text x="760" y="206" fill="#94a3b8" font-size="8" text-anchor="middle" font-family="JetBrains Mono, monospace">Prometheus + Grafana 实时健康监控</text>
        <rect x="40" y="252" width="180" height="56" rx="6" fill="rgba(6, 78, 59, 0.4)" stroke="#34d399" stroke-width="1.5"/>
        <text x="130" y="274" fill="white" font-size="10" font-weight="600" text-anchor="middle" font-family="JetBrains Mono, monospace">规划引擎 (Planning)</text>
        <text x="130" y="292" fill="#94a3b8" font-size="9" text-anchor="middle" font-family="JetBrains Mono, monospace">任务分解 / 目标规划 / 反思迭代</text>
        <rect x="250" y="252" width="180" height="56" rx="6" fill="rgba(6, 78, 59, 0.4)" stroke="#34d399" stroke-width="1.5"/>
        <text x="340" y="274" fill="white" font-size="12" font-weight="600" text-anchor="middle" font-family="JetBrains Mono, monospace">MCP 工具系统</text>
        <text x="340" y="292" fill="#94a3b8" font-size="8" text-anchor="middle" font-family="JetBrains Mono, monospace">文件/网络/进程/扩展/外设 共36个工具</text>
        <rect x="460" y="252" width="180" height="56" rx="6" fill="rgba(30, 41, 59, 0.5)" stroke="#94a3b8" stroke-width="1.5"/>
        <text x="550" y="274" fill="white" font-size="10" font-weight="600" text-anchor="middle" font-family="JetBrains Mono, monospace">技能系统 (Skills)</text>
        <text x="550" y="292" fill="#94a3b8" font-size="8" text-anchor="middle" font-family="JetBrains Mono, monospace">自省反思 / 记忆摘要 / 情感表达 / 主动建议 / 上下文感知 / 安全守护 / 语音交互</text>
        <rect x="670" y="252" width="180" height="56" rx="6" fill="rgba(136, 19, 55, 0.4)" stroke="#fb7185" stroke-width="1.5"/>
        <text x="760" y="274" fill="white" font-size="12" font-weight="600" text-anchor="middle" font-family="JetBrains Mono, monospace">安全守护引擎</text>
        <text x="760" y="292" fill="#94a3b8" font-size="8" text-anchor="middle" font-family="JetBrains Mono, monospace">安全审查 / 风险拦截 / XSS/SQL注入防护</text>
        <rect x="40" y="338" width="180" height="56" rx="6" fill="rgba(30, 41, 59, 0.5)" stroke="#94a3b8" stroke-width="1.5"/>
        <text x="130" y="360" fill="white" font-size="10" font-weight="600" text-anchor="middle" font-family="JetBrains Mono, monospace">扩展管理 (Extensions)</text>
        <text x="130" y="378" fill="#94a3b8" font-size="9" text-anchor="middle" font-family="JetBrains Mono, monospace">技能/MCP服务/通道/插件 动态加载</text>
        <rect x="250" y="338" width="180" height="56" rx="6" fill="rgba(120, 53, 15, 0.3)" stroke="#fbbf24" stroke-width="1.5"/>
        <text x="340" y="360" fill="white" font-size="12" font-weight="600" text-anchor="middle" font-family="JetBrains Mono, monospace">Windows 物理载体</text>
        <text x="340" y="378" fill="#94a3b8" font-size="8" text-anchor="middle" font-family="JetBrains Mono, monospace">CPU · 内存 · 硬盘 · 电池 · 网络 — 物理硬件层</text>
        <rect x="460" y="338" width="180" height="56" rx="6" fill="rgba(8, 51, 68, 0.4)" stroke="#22d3ee" stroke-width="1.5"/>
        <text x="550" y="360" fill="white" font-size="12" font-weight="600" text-anchor="middle" font-family="JetBrains Mono, monospace">Web 交互界面</text>
        <text x="550" y="378" fill="#94a3b8" font-size="8" text-anchor="middle" font-family="JetBrains Mono, monospace">Flask Web UI / 语音交互 / 实时状态面板</text>

        <!-- Legend -->
        <text x="750" y="30" fill="white" font-size="10" font-weight="600">Legend</text>
        <rect x="750" y="56" width="16" height="10" rx="2" fill="rgba(8, 51, 68, 0.4)" stroke="#22d3ee" stroke-width="1"/>
        <text x="772" y="65" fill="#94a3b8" font-size="8" font-family="JetBrains Mono, monospace">Frontend</text>
        <rect x="750" y="70" width="16" height="10" rx="2" fill="rgba(6, 78, 59, 0.4)" stroke="#34d399" stroke-width="1"/>
        <text x="772" y="79" fill="#94a3b8" font-size="8" font-family="JetBrains Mono, monospace">Backend</text>
        <rect x="750" y="84" width="16" height="10" rx="2" fill="rgba(76, 29, 149, 0.4)" stroke="#a78bfa" stroke-width="1"/>
        <text x="772" y="93" fill="#94a3b8" font-size="8" font-family="JetBrains Mono, monospace">Database</text>
        <rect x="750" y="98" width="16" height="10" rx="2" fill="rgba(120, 53, 15, 0.3)" stroke="#fbbf24" stroke-width="1"/>
        <text x="772" y="107" fill="#94a3b8" font-size="8" font-family="JetBrains Mono, monospace">Cloud Service</text>
        <rect x="750" y="112" width="16" height="10" rx="2" fill="rgba(136, 19, 55, 0.4)" stroke="#fb7185" stroke-width="1"/>
        <text x="772" y="121" fill="#94a3b8" font-size="8" font-family="JetBrains Mono, monospace">Security</text>
      </svg>
    </div>

    <!-- Info Cards -->
    
      <div class="card">
        <div class="card-header">
          <div class="card-dot emerald"></div>
          <h3>Backend (10)</h3>
        </div>
        <ul>
                    <li>&bull; LLM 大模型大脑</li>
          <li>&bull; 行为控制器</li>
          <li>&bull; 感知系统 (Sensors)</li>
          <li>&bull; 记忆系统 (Memory)</li>
          <li>&bull; 认知系统 (Cognitive)</li>
          <li>&bull; 人格系统 (Persona)</li>
          <li>&bull; 生命周期追踪 (LifeTrace)</li>
          <li>&bull; 监控系统 (Monitoring)</li>
          <li>&bull; 规划引擎 (Planning)</li>
          <li>&bull; MCP 工具系统</li>
        </ul>
      </div>
      <div class="card">
        <div class="card-header">
          <div class="card-dot None"></div>
          <h3>External (2)</h3>
        </div>
        <ul>
                    <li>&bull; 技能系统 (Skills)</li>
          <li>&bull; 扩展管理 (Extensions)</li>
        </ul>
      </div>
      <div class="card">
        <div class="card-header">
          <div class="card-dot rose"></div>
          <h3>Security (1)</h3>
        </div>
        <ul>
                    <li>&bull; 安全守护引擎</li>
        </ul>
      </div>
      <div class="card">
        <div class="card-header">
          <div class="card-dot amber"></div>
          <h3>Cloud Service (1)</h3>
        </div>
        <ul>
                    <li>&bull; Windows 物理载体</li>
        </ul>
      </div>
      <div class="card">
        <div class="card-header">
          <div class="card-dot cyan"></div>
          <h3>Frontend (1)</h3>
        </div>
        <ul>
                    <li>&bull; Web 交互界面</li>
        </ul>
      </div>


    <!-- Footer -->
    <p class="footer">
      云枢 (Yunshu) — 数字生命体系统架构 &bull; Generated on 2026
    </p>
  </div>
</body>
</html>