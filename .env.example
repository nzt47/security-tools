# Digital Life 环境变量配置示例
# 复制此文件为 .env 并填入真实配置

# ========================================
# 错误上报配置
# ========================================

# 控制台上报
ERROR_REPORTING_CONSOLE_LEVEL=warning

# 文件上报
ERROR_REPORTING_FILE_ENABLED=true
ERROR_REPORTING_FILE_PATH=./logs/digital_life_errors.log
ERROR_REPORTING_FILE_LEVEL=error

# Webhook 上报（可选）
ERROR_REPORTING_WEBHOOK_ENABLED=false
ERROR_REPORTING_WEBHOOK_URL=https://your-webhook-url.com/endpoint
ERROR_REPORTING_WEBHOOK_TIMEOUT=5
ERROR_REPORTING_WEBHOOK_LEVEL=error

# Slack 上报（可选）
ERROR_REPORTING_SLACK_ENABLED=false
ERROR_REPORTING_SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK
ERROR_REPORTING_SLACK_CHANNEL=#digital-life-alerts
ERROR_REPORTING_SLACK_USERNAME=Digital Life Bot
ERROR_REPORTING_SLACK_ICON=:robot_face:
ERROR_REPORTING_SLACK_LEVEL=warning

# ========================================
# 功能开关
# ========================================

# Python 沙盒功能（默认关闭，设置为 true 启用）
YUNSHU_FEATURE_SANDBOX=false

# ========================================
# 其他配置（根据需要添加）
# ========================================

# ========================================
# GlitchTip 错误追踪平台配置
# ========================================
# 用于 docker/glitchtip/docker-compose.yml + orm_setup_inline.py
# 启动方式: cd docker/glitchtip && cp .env.example .env && docker compose up -d

# GlitchTip 管理员密码（orm_setup_inline.py 读取，缺失即终止）
# 生产环境请使用强密码（>=12 字符，含大小写+数字+符号）
GLITCHTIP_ADMIN_PASSWORD=

# GlitchTip 管理员邮箱（默认 admin@local.test，可自定义）
GLITCHTIP_ADMIN_EMAIL=admin@local.test

# GlitchTip 访问域名（docker-compose.yml 已有默认值）
GLITCHTIP_DOMAIN=http://localhost:8000

# PostgreSQL 数据库配置（docker-compose.yml 已有默认值）
POSTGRES_DB=glitchtip
POSTGRES_USER=glitchtip
POSTGRES_PASSWORD=glitchtip_dev_pass

# Django SECRET_KEY（生产环境务必修改）
SECRET_KEY=dev-secret-key-change-in-production

# ========================================
# P3 离线模型配置（predownload_model.py 生成）
# ========================================
# 预下载模型后启用离线模式，避免运行时网络请求
# 启用前需先运行: python scripts/predownload_model.py --all
HF_HUB_OFFLINE=1
TRANSFORMERS_OFFLINE=1
