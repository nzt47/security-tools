# Digital Life 环境变量配置示例
# 复制此文件为 .env 并填入真实配置
# 本文件可作为模板提交到仓库，.env 会被 .gitignore 忽略

# ========================================
# LLM 服务配置（唯一来源）
# ========================================
# 提供商: openai / anthropic / siliconflow / ollama
LLM_PROVIDER=openai

# API Key（填入实际使用的 LLM key）
LLM_API_KEY=sk-your-api-key

# 模型名称
# OpenAI: gpt-4o / gpt-4-turbo / gpt-4
# Anthropic: claude-3-5-sonnet-latest / claude-3-opus
# SiliconFlow: Qwen/Qwen2.5-7B-Instruct / deepseek-ai/DeepSeek-V2.5
# Ollama: llama3 / qwen2.5 / glm4
LLM_MODEL=gpt-4o

# API 端点（可选，用于兼容 OpenAI 格式的服务）
# OpenAI: https://api.openai.com/v1
# SiliconFlow: https://api.siliconflow.cn/v1
# Ollama: http://localhost:11434/v1
LLM_BASE_URL=

# OpenAI 兼容（config.yaml 中通过 ${OPENAI_API_KEY} 引用）
OPENAI_API_KEY=sk-your-openai-key

# Anthropic Claude
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key

# ========================================
# 错误上报配置
# ========================================

# 控制台上报
ERROR_REPORTING_CONSOLE_LEVEL=warning

# 文件上报
ERROR_REPORTING_FILE_ENABLED=true
ERROR_REPORTING_FILE_PATH=./logs/digital_life_errors.log
ERROR_REPORTING_FILE_LEVEL=error

# Webhook 上报（可选）
ERROR_REPORTING_WEBHOOK_ENABLED=false
ERROR_REPORTING_WEBHOOK_URL=https://your-webhook-url.com/endpoint
ERROR_REPORTING_WEBHOOK_TIMEOUT=5
ERROR_REPORTING_WEBHOOK_LEVEL=error

# Slack 上报（可选）
ERROR_REPORTING_SLACK_ENABLED=false
ERROR_REPORTING_SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK
ERROR_REPORTING_SLACK_CHANNEL=#digital-life-alerts
ERROR_REPORTING_SLACK_USERNAME=Digital Life Bot
ERROR_REPORTING_SLACK_ICON=:robot_face:
ERROR_REPORTING_SLACK_LEVEL=warning

# ========================================
# 功能开关
# ========================================

# Python 沙盒功能（默认关闭，设置为 true 启用）
YUNSHU_FEATURE_SANDBOX=false

# ========================================
# 其他配置（根据需要添加）
# ========================================

# ========================================
# DeepSeek API 配置（用于 /api/news 翻译功能）
# ========================================

# DeepSeek API Key
# 获取地址：https://platform.deepseek.com/api_keys
# 旧 key（sk-ddf2****45a3）已撤销，请使用新申请的 key
DEEPSEEK_API_KEY=sk-your-deepseek-key

# DeepSeek API 端点（默认即可，无需修改）
DEEPSEEK_BASE_URL=https://api.deepseek.com/chat/completions
