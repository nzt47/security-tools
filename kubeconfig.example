apiVersion: v1
kind: Config
preferences: {}

clusters:
- cluster:
    certificate-authority-data: <BASE64_ENCODED_CA>
    server: https://<KUBERNETES_API_SERVER>:<PORT>
  name: <CLUSTER_NAME>

contexts:
- context:
    cluster: <CLUSTER_NAME>
    namespace: <NAMESPACE>
    user: <USER_NAME>
  name: <CONTEXT_NAME>

current-context: <CONTEXT_NAME>

users:
- name: <USER_NAME>
  user:
    token: <BEARER_TOKEN>
    # 或者使用客户端证书
    # client-certificate-data: <BASE64_ENCODED_CLIENT_CERT>
    # client-key-data: <BASE64_ENCODED_CLIENT_KEY>
